{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --env-file=../../.env --enable-source-maps ./dist/index.mjs",
    "check:db": "node --env-file=../../.env ./src/scripts/check-db.mjs",
    "check:tables": "node --env-file=../../.env ./src/scripts/list-tables.mjs",
    "db:tables": "node --env-file=../../.env ./src/scripts/db-list-all-tables.mjs",
    "db:query": "node --env-file=../../.env ./src/scripts/db-query.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "protobufjs": "^8.0.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/qrcode": "^1.5.6",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
