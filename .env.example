# Core API
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# PostgreSQL
# Replace with your actual local/remote DB connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/revo_am

# Admin auth/email
ADMIN_EMAIL=admin@example.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# WhatsApp Cloud API (Meta)
# Required if you want to send WhatsApp messages from dashboard automation.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Important: create a Gmail App Password from your Google account security settings.
# OTP login will not work until GMAIL_APP_PASSWORD is set.

# Frontend (optional; defaults already exist in vite.config.ts)
BASE_PATH=/
